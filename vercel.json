{
  "version": 2,
  "builds": [
    {
      "src": "api/*.cjs",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/$1.cjs"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
